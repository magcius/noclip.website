{
  "name": "@jstpierre/noclip.website",
  "private": true,
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@rsbuild/core": "^1.4.4",
    "@rsbuild/plugin-type-check": "^1.2.3",
    "@types/node": "^22.16.0",
    "@types/parseurl": "^1.3.3",
    "@types/pngjs": "^6.0.5",
    "@types/send": "^0.17.5",
    "@types/webxr": "^0.5.22",
    "@webgpu/types": "^0.1.64",
    "@xmldom/xmldom": "^0.9.8",
    "buffer": "^6.0.3",
    "parseurl": "^1.3.3",
    "pngjs": "^7.0.0",
    "send": "^1.2.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "webm-muxer": "^5.1.4",
    "wireit": "^0.14.12"
  },
  "dependencies": {
    "crc-32": "^1.2.2",
    "fzstd": "^0.1.1",
    "gl-matrix": "3.4.3",
    "librw": "^0.4.0",
    "reflect-metadata": "^0.2.2",
    "tiff": "^6.2.0"
  },
  "scripts": {
    "start": "wireit",
    "build": "wireit",
    "build:cargo-build-debug": "wireit",
    "build:cargo-build-release": "wireit",
    "build:ZeldaWindWaker": "tsx src/ZeldaWindWaker/tools/zww_extractor.ts",
    "build:ZeldaTwilightPrincess": "tsx src/ZeldaTwilightPrincess/tools/ztp_extractor.ts",
    "build:DonkeyKong64": "tsx src/DonkeyKong64/tools/extractor.ts",
    "build:KatamariDamacy": "tsx src/KatamariDamacy/tools/extractor.ts",
    "build:FinalFantasyX": "tsx src/FinalFantasyX/tools/extractor.ts",
    "build:zelview": "tsx src/zelview/tools/extractor.ts",
    "build:JetSetRadio": "tsx src/JetSetRadio/tools/extractor.ts",
    "build:BanjoKazooie": "tsx src/BanjoKazooie/tools/extractor.ts",
    "build:TheWitness": "tsx src/TheWitness/tools/extractor.ts",
    "build:Fez": "tsx src/Fez/tools/extractor.ts",
    "build:RatchetAndClank": "tsx src/RatchetAndClank/tools/extractor.ts",
    "typecheck": "tsc -w --noEmit"
  },
  "wireit": {
    "build": {
      "command": "rsbuild build",
      "files": [
        "src/**/*",
        "rsbuild.config.ts",
        "tsconfig.json"
      ],
      "dependencies": ["build:cargo-build-release"]
    },
    "start": {
      "command": "rsbuild dev",
      "dependencies": [
        {
          "script": "build:cargo-build-debug",
          "cascade": false
        }
      ],
      "service": true,
      "files": []
    },
    "build:cargo-build-debug": {
      "command": "cd rust && cargo bin wasm-pack build --dev --out-dir ./pkg --out-name index --target web",
      "files": [
        "rust/Cargo.toml",
        "rust/src/**/*.rs",
        "rust/noclip-macros/Cargo.toml",
        "rust/noclip-macros/src/**/*.rs"
      ],
      "output": [
        "rust/pkg/index.js",
        "rust/pkg/index.d.ts",
        "rust/pkg/index_bg.wasm",
        "rust/pkg/index_bg.wasm.d.ts"
      ],
      "clean": false
    },
    "build:cargo-build-release": {
      "command": "cd rust && cargo bin wasm-pack build --release --out-dir ./pkg --out-name index --target web",
      "files": [
        "rust/Cargo.toml",
        "rust/src/**/*.rs",
        "rust/noclip-macros/Cargo.toml",
        "rust/noclip-macros/src/**/*.rs"
      ],
      "output": [
        "rust/pkg/index.js",
        "rust/pkg/index.d.ts",
        "rust/pkg/index_bg.wasm",
        "rust/pkg/index_bg.wasm.d.ts"
      ],
      "clean": false
    }
  },
  "browserslist": [
    "last 2 Chrome versions"
  ],
  "packageManager": "pnpm@10.6.2+sha256.20072a1f6edd17646ea9234bf32c42d563dad37b2973e97a2dde5c17774a824d"
}
